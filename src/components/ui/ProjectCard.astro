---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import SkillBadge from "./SkillBadge.astro";

interface Props {
  title: string;
  description: string;
  image: ImageMetadata;
  tags?: string[];
  demoLink?: string | null;
  repoLink?: string | null;
}

const { title, description, image, tags = [], demoLink, repoLink } =
  Astro.props;
---

<article
  class="group flex flex-col overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-lg transition-transform duration-300 hover:scale-[1.02] hover:shadow-xl dark:border-gray-800 dark:bg-gray-800"
>
  <div class="aspect-video overflow-hidden bg-gray-100 dark:bg-gray-900">
    <Image
      src={image}
      alt={title}
      width={800}
      height={600}
      loading="lazy"
      class="h-full w-full rounded-t-lg object-cover transition-transform duration-300 group-hover:scale-105"
    />
  </div>

  <div class="flex flex-1 flex-col p-6">
    <h3 class="text-lg font-bold text-gray-900 dark:text-white">
      {title}
    </h3>
    <p class="mt-2 flex-1 text-sm leading-relaxed text-gray-600 dark:text-gray-300">
      {description}
    </p>

    {
      tags.length > 0 && (
        <ul class="mt-4 flex flex-wrap gap-2">
          {tags.map((tag) => (
            <li>
              <SkillBadge name={tag} />
            </li>
          ))}
        </ul>
      )
    }

    {
      (demoLink || repoLink) && (
        <div class="mt-6 flex flex-wrap gap-3">
          {demoLink && (
            <a
              href={demoLink}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg bg-gray-900 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-gray-700 dark:bg-white dark:text-gray-900 dark:hover:bg-gray-200"
            >
              <svg
                class="h-4 w-4"
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"
                />
              </svg>
              Live Demo
            </a>
          )}
          {repoLink && (
            <a
              href={repoLink}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 transition-colors hover:bg-gray-100 dark:border-gray-600 dark:text-gray-200 dark:hover:bg-gray-700"
            >
              <svg
                class="h-4 w-4"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.606-.014 2.898-.014 3.293 0 .322.216.694.825.576C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
              </svg>
              Source Code
            </a>
          )}
        </div>
      )
    }
  </div>
</article>
