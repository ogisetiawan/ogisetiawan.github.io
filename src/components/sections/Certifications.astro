---
import { portfolioData as portfolio } from "../../data/portfolio";
import SkillBadge from "../ui/SkillBadge.astro";

const { certifications } = portfolio;

function parseCoursework(coursework: string): string[] {
  return coursework
    .split(",")
    .map((item) => item.trim())
    .filter(Boolean);
}
---

<section id="certifications" class="mx-auto max-w-6xl px-4 py-20 sm:px-6 lg:px-8">
  <div class="mb-12 text-center">
    <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl dark:text-white">
      Certifications
    </h2>
    <p class="mt-4 text-base text-gray-600 dark:text-gray-400">
      Professional courses and certifications I have completed.
    </p>
  </div>

  <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
    {
      certifications.map((cert) => (
        <article class="group flex flex-col rounded-2xl border border-gray-200 bg-white p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-gray-300 hover:shadow-xl dark:border-gray-800 dark:bg-gray-800 dark:hover:border-gray-700">
          <div class="mb-4 flex items-start justify-between gap-3">
            <div class="flex h-11 w-11 flex-none items-center justify-center rounded-xl bg-gray-100 text-gray-900 transition-colors group-hover:bg-gray-900 group-hover:text-white dark:bg-gray-700 dark:text-white dark:group-hover:bg-white dark:group-hover:text-gray-900">
              <svg
                class="h-6 w-6"
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5"
                />
              </svg>
            </div>
            <time
              datetime={cert.date}
              class="rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-600 dark:bg-gray-700 dark:text-gray-300"
            >
              {cert.date}
            </time>
          </div>

          <h3 class="text-lg font-bold leading-snug text-gray-900 dark:text-white">
            {cert.name}
          </h3>

          <p class="mt-1 text-sm font-medium text-gray-500 dark:text-gray-400">
            {cert.issuer}
          </p>

          <p class="mt-3 flex-1 text-sm leading-relaxed text-gray-600 dark:text-gray-300">
            {cert.coursework}
          </p>

          <ul class="mt-4 flex flex-wrap gap-2 border-t border-gray-100 pt-4 dark:border-gray-700">
            {parseCoursework(cert.coursework).map((topic) => (
              <li>
                <SkillBadge name={topic} />
              </li>
            ))}
          </ul>

          {
            cert.certificate && (
              <div class="mt-5 border-t border-gray-100 pt-5 dark:border-gray-700">
                <a
                  href={cert.certificate}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="cert-btn group/btn inline-flex w-full items-center justify-center gap-2.5 rounded-xl bg-gray-900 px-4 py-3 text-sm font-semibold text-white shadow-sm transition-all duration-200 hover:bg-gray-800 hover:shadow-md active:scale-[0.98] focus:outline-none focus-visible:ring-2 focus-visible:ring-gray-900 focus-visible:ring-offset-2 dark:bg-white dark:text-gray-900 dark:hover:bg-gray-100 dark:focus-visible:ring-white dark:focus-visible:ring-offset-gray-800"
                >
                  <svg
                    class="h-4 w-4 shrink-0"
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="2"
                    stroke="currentColor"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"
                    />
                  </svg>
                  <span>View Certificate</span>
                  <svg
                    class="h-4 w-4 shrink-0 transition-transform duration-200 group-hover/btn:translate-x-0.5 group-hover/btn:-translate-y-0.5"
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="2"
                    stroke="currentColor"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"
                    />
                  </svg>
                </a>
              </div>
            )
          }
        </article>
      ))
    }
  </div>
</section>
