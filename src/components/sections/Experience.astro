---
import { portfolioData as portfolio } from "../../data/portfolio";

const { experience, education } = portfolio;
---

<section id="experience" class="mx-auto max-w-6xl px-4 py-20 sm:px-6 lg:px-8">
  <div class="mb-12 text-center">
    <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl dark:text-white">
      Experience & Education
    </h2>
  </div>

  <div class="grid gap-12 lg:grid-cols-2">
    <!-- Work experience timeline -->
    <div>
      <h3 class="mb-8 flex items-center gap-2 text-xl font-bold text-gray-900 dark:text-white">
        <svg
          class="h-6 w-6"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 0 0 .75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 0 0-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0 1 12 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 0 1-.673-.38m0 0A2.18 2.18 0 0 1 3 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 0 1 3.413-.387m7.5 0V5.25A2.25 2.25 0 0 0 13.5 3h-3a2.25 2.25 0 0 0-2.25 2.25v.894m7.5 0a48.667 48.667 0 0 0-7.5 0M12 12.75h.008v.008H12v-.008Z"
          ></path>
        </svg>
        Work Experience
      </h3>

      <ol class="relative border-l border-gray-200 dark:border-gray-700">
        {
          experience.map((job) => (
            <li class="mb-10 ml-6">
              <span class="absolute -left-[9px] flex h-4 w-4 items-center justify-center rounded-full border-2 border-white bg-gray-900 dark:border-gray-900 dark:bg-white" />
              <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm dark:border-gray-800 dark:bg-gray-800">
                <div class="mb-2 flex flex-wrap items-center gap-2">
                  <time class="rounded bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600 dark:bg-gray-700 dark:text-gray-300">
                    {job.startDate} - {job.endDate}
                  </time>
                  {job.current && (
                    <span class="rounded bg-green-100 px-2 py-0.5 text-xs font-medium text-green-700 dark:bg-green-900/40 dark:text-green-400">
                      Current
                    </span>
                  )}
                </div>
                <h4 class="text-base font-bold text-gray-900 dark:text-white">
                  {job.role}
                </h4>
                <p class="mb-3 text-sm font-medium text-gray-500 dark:text-gray-400">
                  {job.company}
                </p>
                <ul class="list-disc space-y-1 pl-4 text-sm text-gray-600 dark:text-gray-300">
                  {job.responsibilities.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
            </li>
          ))
        }
      </ol>
    </div>

    <!-- Education timeline -->
    <div>
      <h3 class="mb-8 flex items-center gap-2 text-xl font-bold text-gray-900 dark:text-white">
        <svg
          class="h-6 w-6"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5"
          ></path>
        </svg>
        Education
      </h3>

      <ol class="relative border-l border-gray-200 dark:border-gray-700">
        {
          education.map((edu) => (
            <li class="mb-10 ml-6">
              <span class="absolute -left-[9px] flex h-4 w-4 items-center justify-center rounded-full border-2 border-white bg-gray-900 dark:border-gray-900 dark:bg-white" />
              <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm dark:border-gray-800 dark:bg-gray-800">
                <time class="mb-2 inline-block rounded bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-600 dark:bg-gray-700 dark:text-gray-300">
                  {edu.startDate} - {edu.endDate}
                </time>
                <h4 class="text-base font-bold text-gray-900 dark:text-white">
                  {edu.degree}
                  {edu.field ? ` - ${edu.field}` : ""}
                </h4>
                <p class="mb-3 text-sm font-medium text-gray-500 dark:text-gray-400">
                  {edu.institution}
                </p>
                <p class="text-sm text-gray-600 dark:text-gray-300">
                  {edu.description}
                </p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>
