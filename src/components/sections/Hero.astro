---
import { portfolioData as portfolio } from "../../data/portfolio";

const { name, tagline, bio } = portfolio.profile;
---

<section
  id="home"
  class="flex min-h-[90vh] flex-col items-center justify-center px-4 py-20 text-center sm:px-6 lg:px-8"
>
  <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-gray-500 dark:text-gray-400">
    {portfolio.profile.title}
  </p>

  <h1
    class="max-w-4xl text-4xl font-extrabold tracking-tight text-gray-900 sm:text-6xl lg:text-7xl dark:text-white"
  >
    {name}
  </h1>

  <p
    class="mt-6 max-w-2xl text-xl font-bold text-gray-700 sm:text-2xl dark:text-gray-200"
  >
    {tagline}
  </p>

  <p class="mt-4 max-w-2xl text-base leading-relaxed text-gray-600 dark:text-gray-400">
    {bio}
  </p>

  <div class="mt-10 flex flex-col gap-4 sm:flex-row">
    <a
      href="#projects"
      class="inline-flex items-center justify-center rounded-lg bg-gray-900 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-gray-700 dark:bg-white dark:text-gray-900 dark:hover:bg-gray-200"
    >
      Lihat Proyek
    </a>
    <a
      href="/resume.pdf"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center justify-center gap-2 rounded-lg border border-gray-300 px-8 py-3 text-base font-semibold text-gray-700 transition-colors hover:bg-gray-100 dark:border-gray-600 dark:text-gray-200 dark:hover:bg-gray-800"
    >
      <svg
        class="h-5 w-5"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        aria-hidden="true"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5"
        ></path>
      </svg>
      Download CV
    </a>
  </div>
</section>
