---
// Import Layout dan Komponen Section yang sudah dibuat di Step 1 & 3
import BaseLayout from '../components/layout/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import About from '../components/sections/About.astro';
import Projects from '../components/sections/Projects.astro';
import Experience from '../components/sections/Experience.astro';
import Certifications from '../components/sections/Certifications.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import Contact from '../components/sections/Contact.astro';
---

<BaseLayout>
  <!-- Main wrapper dengan background dinamis untuk Dark Mode -->
  <main class="bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 transition-colors duration-300">
    
    <!-- Section 1: Hero (id="home" untuk navigasi navbar) -->
    <section id="home">
      <Hero />
    </section>

    <!-- Section 2: About -->
    <About />
    
    <!-- Section 3: Projects -->
    <section id="projects">
      <Projects />
    </section>
    
    <!-- Section 4: Experience -->
    <section id="experience">
      <Experience />
    </section>

    <!-- Section 5: Certifications -->
    <Certifications />

    <!-- Section 6: Testimonials -->
    <Testimonials />

    <!-- Section 7: Contact -->
    <section id="contact">
      <Contact />
    </section>

  </main>
</BaseLayout>